# Genesis production — set in Render / Railway / host dashboard (never commit real values)

GENESIS_ENV=production
PORT=8000
HOST=0.0.0.0

# Persistent memory volume path (mount /data on cloud)
GENESIS_MEMORY_DIR=/data

# Public frontend URL (Vercel)
GENESIS_PUBLIC_URL=https://your-app.vercel.app
GENESIS_CORS_ORIGINS=https://your-app.vercel.app

# AI Workforce — at least one cloud key recommended
GENESIS_GROQ_API_KEY=
GENESIS_GROQ_MODEL=llama-3.3-70b-versatile
GENESIS_GEMINI_API_KEY=
GENESIS_GEMINI_MODEL=gemini-2.0-flash
GENESIS_OPENROUTER_API_KEY=
GENESIS_LLM_API_KEY=

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Never enable in production
# GENESIS_DEV_MODE=1
