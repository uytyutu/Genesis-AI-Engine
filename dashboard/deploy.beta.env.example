# Beta environment — copy to Railway + Vercel (NOT production)
# Domain: genesis-ai-engine.com

# --- Railway service: genesis-beta (branch: cursor/mission1-genesis-brain-public-layer) ---
GENESIS_MEMORY_DIR=/data
GENESIS_PUBLIC_URL=https://beta.genesis-ai-engine.com
GENESIS_CORS_ORIGINS=https://beta.genesis-ai-engine.com
# Optional custom API domain (Railway → Settings → Custom Domain):
# GENESIS_PUBLIC_URL=https://api-beta.genesis-ai-engine.com
# GENESIS_CORS_ORIGINS=https://beta.genesis-ai-engine.com

GENESIS_LLM_API_KEY=
STRIPE_SECRET_KEY=sk_test_...
# Use test keys only on beta

# --- Vercel project: genesis-beta (root: dashboard/frontend, branch: cursor/mission1-...) ---
NEXT_PUBLIC_API_URL=https://genesis-ai-engine-beta.up.railway.app
# Or with custom domain: https://api-beta.genesis-ai-engine.com
NEXT_PUBLIC_SITE_URL=https://beta.genesis-ai-engine.com
