    "client_nav_paths": ["/projects"],
    "surfaces": {
      "public": {
        "scenario": "Узнать → попробовать → скачать",
        "user_flow": ["Главная", "Lite Vector", "Услуги", "Скачать приложение"]
      },
      "client": {
        "scenario": "Открыть компанию → поговорить с Vector → получить результат",
        "user_flow": ["Компания", "Vector", "Проекты", "Результат"]
      },
      "ceo": {
        "scenario": "Управлять компанией → принимать решения → развивать продукт",
        "user_flow": ["Mission Control", "Factory", "Finance", "Стратегия"]
      }
    }
  },
  "kernel_layers": [
    "product_truth",
    "delivery",
    "memory",
    "planner",
    "identity",
    "kernel"
