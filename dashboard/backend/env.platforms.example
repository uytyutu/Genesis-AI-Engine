# Биржи разметки — вставь ключи в dashboard/backend/.env.local после регистрации.
# Genesis НЕ может подключить биржи без твоего аккаунта.

# Уже работает без бирж:
GENESIS_GROQ_API_KEY=
GOOGLE_PLACES_API_KEY=

# Scale AI — https://scale.com/ → Dashboard → API Key
# Вставь ключ сюда (начинается с live_...) и перезапусти Genesis.exe:
SCALE_API_KEY=

# Toloka — https://toloka.ai/
TOLOKA_API_TOKEN=

# Appen — https://appen.com/
APPEN_API_KEY=

# Amazon MTurk (Requester) — AWS IAM
AWS_ACCESS_KEY_ID=
MTURK_AWS_SECRET_ACCESS_KEY=

# Hive — https://thehive.ai/
HIVE_API_KEY=

# Dataloop — https://dataloop.ai/
DATALOOP_API_KEY=

# Labelbox — https://labelbox.com/
LABELBOX_API_KEY=

# --- Инфраструктурный Рой (ноутбук = пульт, VPS = исполнение) ---
# local = dry-run тесты на ноутбуке (оставь так до 100 dry-run строк в консоли)
FARM_EXECUTION_MODE=local
# URL worker pool (Genesis backend на VPS): http://YOUR_VPS:8100
FARM_WORKER_POOL_URL=
# Опционально — общий секрет между пультом и VPS
FARM_WORKER_POOL_TOKEN=

# dry_run = учебный · live = внешние API бирж (после ключей в .env.local)
FARM_LIVE_MODE=dry_run

# Пассивные ноды (прогноз uptime-дохода — после подключения сети)
FARM_NODE_COUNT=0
FARM_NODE_DAILY_USD=0.07
