# Live farm — скопируй в dashboard/backend/.env.local когда готов (НЕ коммить!)
# CEO: Withdraw на Stripe только вручную в кабинете Scale/Toloka

FARM_EXECUTION_MODE=remote
FARM_LIVE_MODE=live
FARM_WORKER_POOL_URL=http://YOUR_VPS:8100
FARM_WORKER_POOL_TOKEN=
FARM_PAYOUT_THRESHOLD_USD=10

SCALE_API_KEY=
TOLOKA_API_TOKEN=
# Toloka Pipeline API v2 (OpenAPI: api-1.json в корне репо)
TOLOKA_API_BASE_URL=https://platform.toloka.ai
TOLOKA_AUTO_SUBMIT=1
# Опционально — иначе берётся первый active project / создаётся dataset virtus-core-labels
TOLOKA_PROJECT_ID=
TOLOKA_DATASET_ID=
TOLOKA_PIPELINE_ID=
TOLOKA_TRIGGER_RUN=1
# Finance Guard — сравнение LLM cost vs ожидаемая оплата Toloka
TOLOKA_EXPECTED_PAY_EUR=0.05
FARM_INFRA_EUR_PER_HOUR=0
FARM_FINANCE_GUARD_STOP=0
GENESIS_GROQ_API_KEY=
