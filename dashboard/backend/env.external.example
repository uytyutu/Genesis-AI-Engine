# External free-tier capabilities — ALL OFF by default (Mission 1 Freeze).
# Copy into dashboard/backend/.env.local only when CEO approves activation.
# LLM chain Groq → Gemini → OpenRouter → Ollama is NEVER replaced by these.

# --- Mission1 approved adapters (runtime ready) ---
# OSM Nominatim → Factory maps embed (fallback: Google Maps embed)
# GENESIS_CAP_NOMINATIM=1

# Wikipedia REST — order insights enrichment only (cite source; not verified fact)
# GENESIS_CAP_WIKIPEDIA=1

# Wikidata — city/entity hint in insights (cite source; not verified fact)
# GENESIS_CAP_WIKIDATA=1

# --- Registered, not activated (no adapter / wait for commercial events) ---
# GENESIS_CAP_TELEGRAM=1
# GENESIS_TELEGRAM_BOT_TOKEN=

# GENESIS_CAP_QRSERVER=1

# GENESIS_CAP_HIBP=1
# GENESIS_HIBP_API_KEY=

# GENESIS_CAP_VIRUSTOTAL=1
# GENESIS_VIRUSTOTAL_API_KEY=

# GENESIS_CAP_HUGGINGFACE=1
# GENESIS_HF_TOKEN=

# GENESIS_CAP_OPEN_METEO=1
