# Скопируйте в dashboard/backend/.env или .env.local (оба в gitignore).
# Никогда не коммитьте реальные ключи.

# Groq (рекомендуется для Engine outreach)
GENESIS_GROQ_API_KEY=
# или: GROQ_API_KEY=

# OpenAI (запасной / Vector Brain)
OPENAI_API_KEY=
# или: GENESIS_LLM_API_KEY=sk-...
# GENESIS_LLM_MODEL=gpt-4o-mini

# Claude / Anthropic (через OpenRouter или прямой ключ) — Factory research Claude Engine
GENESIS_ANTHROPIC_API_KEY=
# GENESIS_ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# GENESIS_ANTHROPIC_MODEL=anthropic/claude-sonnet-4
# или общий OpenRouter:
# GENESIS_OPENROUTER_API_KEY=

# Kimi / Moonshot — Virtus Workforce + optional Factory research LLM
GENESIS_KIMI_API_KEY=
# или: MOONSHOT_API_KEY=
# GENESIS_KIMI_BASE_URL=https://api.moonshot.ai/v1
# GENESIS_KIMI_MODEL=moonshot-v1-128k
# Factory research provider override: claude | kimi | openrouter
# FACTORY_RESEARCH_LLM=claude

# Опционально
# GENESIS_GROQ_MODEL=llama-3.3-70b-versatile

# Hive AI (media moderation / OCR / AI-detection) — see env.hive.example
# HIVE_API_KEY=
# HIVE_API_URL=https://api.thehive.ai
