# Hive AI — media moderation / OCR / AI-detection (platform module, not Path A)
# Copy into dashboard/backend/.env.local — NEVER commit real keys
#
# HIVE_API_KEY=your_project_token
# HIVE_API_URL=https://api.thehive.ai
#
# Auth header: authorization: token <HIVE_API_KEY>
# Sync:  POST {HIVE_API_URL}/api/v2/task/sync
# Async: POST {HIVE_API_URL}/api/v2/task/async
#
# Payload shape depends on the Hive project/model bound to the key.
# Do not wire into Factory until Path A Gate 1 PASS + first client.
