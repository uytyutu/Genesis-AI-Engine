# L-001 — Gewerbe / Impressum (copy into dashboard/backend/.env.local, never commit)
# Voraussetzung: Gewerbeanmeldung beim zuständigen Gewerbeamt (DE)
# Danach: py scripts/bootstrap_legal_from_env.py  →  impressum_publishable=true
GENESIS_LEGAL_OPERATOR_NAME=
GENESIS_LEGAL_LEGAL_FORM=Einzelunternehmen
