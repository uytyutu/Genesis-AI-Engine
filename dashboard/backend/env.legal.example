# L-001 — Gewerbe / Impressum intake (copy into dashboard/backend/.env.local — NEVER commit)
#
# When you have Gewerbeanmeldung / Steuerliche Erfassung, fill from the documents:
#   Gewerbeanmeldung → Name, Anschrift, Rechtsform
#   Finanzamt / USt → USt-IdNr. (if issued; Kleinunternehmer may leave empty)
#   Contact → public email + phone for Impressum
#
# Required for impressum_publishable=true:
#   OPERATOR_NAME, ADDRESS_STREET, ADDRESS_ZIP, ADDRESS_CITY, EMAIL
#
# Then: py scripts/bootstrap_legal_from_env.py
#
GENESIS_LEGAL_OPERATOR_NAME=
GENESIS_LEGAL_LEGAL_FORM=Einzelunternehmen
GENESIS_LEGAL_TRADE_NAME=Virtus Core
GENESIS_LEGAL_ADDRESS_STREET=
GENESIS_LEGAL_ADDRESS_ZIP=
GENESIS_LEGAL_ADDRESS_CITY=
GENESIS_LEGAL_EMAIL=hello@genesis-ai-engine.com
GENESIS_LEGAL_PHONE=
GENESIS_LEGAL_VAT_ID=
GENESIS_LEGAL_MANAGING_DIRECTOR=
GENESIS_LEGAL_HANDELSREGISTER=
GENESIS_LEGAL_REGISTER_COURT=
# Public site URL (also used as website line in Impressum when set):
# GENESIS_PUBLIC_URL=https://…
#
# Outreach stays locked until Impressum is complete — do not enable before Gewerbe:
# GENESIS_OUTREACH_ENABLED=true
#
# Sniper send caps (DE B2B — not mass mail):
# GENESIS_OUTREACH_DAILY_CAP=10
# Hard ceiling in code = 70 / domain / day. Scale via more domains, not higher spam.
#
# Multi-domain rotation (comma-separated From addresses; warm up each domain 2–4 weeks ops-side):
# GENESIS_OUTREACH_FROM_DOMAINS=Virtus Core <hello@ram-service.de>, Virtus <hi@ram-solutions.de>
# Falls back to GENESIS_EMAIL_FROM when unset.
# GENESIS_EMAIL_FROM=Virtus Core <hello@your-domain.de>
