# Public Launch v1 — переменные окружения (скопируйте на хостинг)

# --- Backend (Railway) — Root Directory: . (корень репо, НЕ dashboard/backend) ---
# Builder: Dockerfile в корне репозитория. См. dashboard/RAILWAY_DEPLOY.md
GENESIS_PUBLIC_URL=https://beta.genesis-ai-engine.com
GENESIS_CORS_ORIGINS=https://beta.genesis-ai-engine.com
GENESIS_MEMORY_DIR=/data
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Не включайте sandbox в production:
# GENESIS_PAYMENT_SANDBOX=1

# Stripe Dashboard → Webhooks → endpoint:
# https://YOUR-RAILWAY-URL/api/webhooks/stripe
# Events: checkout.session.completed

# Email receipts (Resend) — verify domain genesis-ai-engine.com in Resend first
RESEND_API_KEY=re_...
GENESIS_EMAIL_FROM=Genesis <hello@genesis-ai-engine.com>
# Gmail API fallback (CEO localhost OAuth → refresh token)
# Google Cloud Console → OAuth client (Desktop or Web) → redirect:
#   http://127.0.0.1:8000/api/owner/gmail/oauth/callback
# Then open http://127.0.0.1:8000/api/owner/gmail (Genesis running) → Connect Gmail
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_SENDER=virtuscoreit@gmail.com
# GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/owner/gmail/oauth/callback
# Support Inbox (Resend Inbound webhook → Railway)
# Create Resend Webhook (event: email.received) → copy Signing secret whsec_…
# RESEND_INBOUND_WEBHOOK_SECRET=whsec_xxxxxxxx
# Webhook URL: https://YOUR-RAILWAY-URL/api/webhooks/resend-inbound
# Production: Svix headers (svix-id / svix-timestamp / svix-signature)
# Local smoke also accepts: Authorization: Bearer <same secret>
GENESIS_SUPPORT_EMAIL=hello@genesis-ai-engine.com

# Genesis AI — Groq first for Engine outreach; OpenAI fallback for Vector Brain
GENESIS_GROQ_API_KEY=gsk_...
# GROQ_API_KEY=gsk_...
# GENESIS_GROQ_MODEL=llama-3.3-70b-versatile
GENESIS_LLM_API_KEY=sk-...
# Alternative: OPENAI_API_KEY=sk-...
GENESIS_LLM_MODEL=gpt-4o-mini

# Google Places — автопилот Engine (поиск компаний в DE, бесплатный лимит на старте)
# console.cloud.google.com → Places API → Credentials → API Key
GOOGLE_PLACES_API_KEY=
# Alternative: OPENAI_API_KEY=sk-...
GENESIS_LLM_MODEL=gpt-4o-mini
# GENESIS_LLM_BASE_URL=https://api.openai.com/v1

# Genesis Voice v2 — TTS chain (OpenAI → ElevenLabs → Google → Azure → browser fallback)
# OpenAI TTS uses GENESIS_LLM_API_KEY by default (voice: nova, model: tts-1-hd)
# GENESIS_TTS_OPENAI_VOICE=nova
# GENESIS_TTS_OPENAI_MODEL=tts-1-hd
# GENESIS_TTS_ELEVENLABS_API_KEY=
# GENESIS_TTS_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# GENESIS_GOOGLE_TTS_API_KEY=
# GENESIS_AZURE_SPEECH_KEY=
# GENESIS_AZURE_SPEECH_REGION=westeurope
# GENESIS_DEEPSEEK_API_KEY=
# GENESIS_OPENROUTER_API_KEY=
# GENESIS_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# GENESIS_OLLAMA_MODEL=llama3.2

# --- Frontend (Vercel) — Root Directory: dashboard/frontend ---
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
